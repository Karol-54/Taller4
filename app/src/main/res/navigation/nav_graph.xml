<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/movieListFragment">

    <fragment
        android:id="@+id/movieListFragment"
        android:name="com.jaimes.comjaimesmovielibrary.ui.MovieListFragment"
        android:label="Mis Películas"
        tools:layout="@layout/fragment_movie_list">

        <action
            android:id="@+id/action_movieListFragment_to_movieDetailFragment"
            app:destination="@id/movieDetailFragment"/>

        <action
            android:id="@+id/action_movieListFragment_to_movieEditFragment"
            app:destination="@id/movieEditFragment"/>

    </fragment>

    <fragment
        android:id="@+id/movieDetailFragment"
        android:name="com.jaimes.comjaimesmovielibrary.ui.MovieDetailFragment"
        android:label="Detalle de Película"
        tools:layout="@layout/fragment_movie_detail">

        <argument
            android:name="movieId"
            app:argType="integer"
            android:defaultValue="-1"/>

        <action
            android:id="@+id/action_movieDetailFragment_to_movieEditFragment"
            app:destination="@id/movieEditFragment"/>

    </fragment>

    <fragment
        android:id="@+id/movieEditFragment"
        android:name="com.jaimes.comjaimesmovielibrary.ui.MovieEditFragment"
        android:label="Editar Película"
        tools:layout="@layout/fragment_movie_edit">

        <argument
            android:name="movieId"
            app:argType="integer"
            android:defaultValue="-1"/>

    </fragment>

</navigation>